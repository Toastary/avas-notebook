SITE_NAME_HEADER=Godstiny's Notebook
SITE_MAIN_LANGUAGE=en
SITE_BASE_URL=https://omniliberal-s-notebook.vercel.app/
SHOW_CREATED_TIMESTAMP=false
TIMESTAMP_FORMAT=MMM dd, yyyy h:mm a
SHOW_UPDATED_TIMESTAMP=true
NOTE_ICON_DEFAULT=
NOTE_ICON_TITLE=false
NOTE_ICON_FILETREE=false
NOTE_ICON_INTERNAL_LINKS=false
NOTE_ICON_BACK_LINKS=false
STYLE_SETTINGS_CSS=body.css-settings-manager { } body.theme-light.css-settings-manager { } body.theme-dark.css-settings-manager { }
STYLE_SETTINGS_BODY_CLASSES=theme-dark mod-windows is-frameless is-hidden-frameless obsidian-app styled-scrollbars show-inline-title is-floating-nav auto-full-screen show-ribbon show-view-header css-settings-manager is-focused
USE_FULL_RESOLUTION_IMAGES=true
UI_BACKLINK_HEADER=Linked mentions
UI_NO_BACKLINKS_MESSAGE=No linked mentions
UI_SEARCH_BUTTON_TEXT=Search...
UI_SEARCH_PLACEHOLDER=Type to search...
UI_SEARCH_ENTER_HINT=to select
UI_SEARCH_NAVIGATE_HINT=to navigate
UI_SEARCH_CLOSE_HINT=to close
UI_SEARCH_NO_RESULTS=No results found
THEME=https://raw.githubusercontent.com/GuiMar10/monochroYou/HEAD/theme.css
BASE_THEME=dark
dgHomeLink=true
dgPassFrontmatter=true
dgShowBacklinks=true
dgShowLocalGraph=true
dgShowInlineTitle=true
dgShowFileTree=true
dgEnableSearch=true
dgShowToc=true
dgLinkPreview=true
dgShowTags=true